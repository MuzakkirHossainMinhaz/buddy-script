# Environment Configuration
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/buddy_script?schema=public
# Optional read replica / Supabase pooler URL for read-heavy endpoints.
DATABASE_READ_URL=
# Keep this low for serverless deployments to avoid exhausting Postgres connections.
DB_POOL_MAX=3

# Redis
REDIS_URL=redis://localhost:6379

# Session
SESSION_SECRET=your-super-secret-session-key-change-in-production
SESSION_NAME=buddy_sid
# Use "none" with secure cookies when frontend and backend are on different Vercel domains.
SESSION_COOKIE_SAME_SITE=lax
# Use this only when frontend and API share a parent domain, e.g. .buddyscript.com.
SESSION_COOKIE_DOMAIN=

# Security
BCRYPT_ROUNDS=12

# CORS (comma-separated origins; set this to your Vercel frontend URL in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Proxy trust (production defaults to one trusted proxy; keep false locally)
TRUST_PROXY=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
FEED_CACHE_TTL_SECONDS=30
# direct keeps counters immediately consistent; buffered records counter_deltas
# for a production worker to flush during very high interaction volume.
COUNTER_WRITE_MODE=direct

# Logging
LOG_LEVEL=debug

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
